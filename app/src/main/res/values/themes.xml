<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SkillExchange" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/saffron</item>
        <item name="colorPrimaryDark">@color/saffron_dark</item>
        <item name="colorAccent">@color/forest_green</item>
        <item name="colorPrimaryVariant">@color/saffron_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/forest_green</item>
        <item name="colorSecondaryVariant">@color/forest_green_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/cream_bg</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/saffron_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="materialButtonStyle">@style/Widget.SkillExchange.Button</item>
        <item name="chipStyle">@style/Widget.SkillExchange.Chip</item>
    </style>

    <style name="Theme.SkillExchange.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/saffron_dark</item>
        <item name="android:statusBarColor">@color/saffron_dark</item>
        <item name="android:navigationBarColor">@color/saffron_dark</item>
    </style>

    <!-- Custom Button Style -->
    <style name="Widget.SkillExchange.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.SkillExchange.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/saffron</item>
        <item name="android:textColor">@color/saffron</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.SkillExchange.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/chip_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.SkillExchange.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.SkillExchange.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
    </style>

    <style name="TextAppearance.SkillExchange.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <style name="TextAppearance.SkillExchange.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <!-- Bottom Sheet -->
    <style name="Theme.SkillExchange.BottomSheet" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/Widget.SkillExchange.BottomSheet</item>
    </style>

    <style name="Widget.SkillExchange.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.SkillExchange.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.SkillExchange.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
</resources>
