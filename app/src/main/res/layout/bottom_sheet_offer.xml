<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@color/divider"
        android:backgroundTint="@color/text_hint" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingBottom="0dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤝  Make a Swap Offer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 hr = 1 pt"
            android:textSize="12sp"
            android:textColor="@color/saffron"
            android:textStyle="bold"
            android:background="@drawable/bg_skill_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

    </LinearLayout>

    <!-- Post Title Reference -->
    <TextView
        android:id="@+id/tv_post_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="@color/card_bg_warm"
        android:padding="10dp" />

    <!-- Form Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <!-- Skill Offered Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_skill_offered"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="I will offer my skill as…"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/saffron"
            app:hintTextColor="@color/saffron">

            <AutoCompleteTextView
                android:id="@+id/actv_skill_offered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:popupBackground="@color/white"
                android:focusable="true"
                android:focusableInTouchMode="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Hours Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="⏱️  Hours to Offer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_hours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:valueFrom="1"
            android:valueTo="8"
            android:stepSize="1"
            android:value="1"
            app:thumbColor="@color/saffron"
            app:trackColorActive="@color/saffron"
            app:trackColorInactive="@color/saffron_light"
            app:haloColor="@color/saffron_light" />

        <TextView
            android:id="@+id/tv_hours_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/saffron_dark"
            android:background="@drawable/bg_skill_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp" />

        <!-- Message (Optional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Message to requester (optional)…"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/saffron"
            app:hintTextColor="@color/saffron">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#F44336"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:indeterminateTint="@color/saffron" />

        <!-- Lottie Success -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_success"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            app:lottie_rawRes="@raw/success_check"
            app:lottie_autoPlay="false"
            app:lottie_loop="false"
            android:visibility="gone" />

        <!-- Send Offer Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_offer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="🚀  Send Swap Offer"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/saffron"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
